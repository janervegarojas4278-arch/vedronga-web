<section id="contacto" class="py-5 bg-light">
  <div class="container">
    <h2 class="text-center mb-4">Contáctanos</h2>
    <div class="row justify-content-center">
      <div class="col-md-8">
        <form id="contactForm" action="https://formspree.io/f/abcd1234" method="POST">
          <div class="mb-3">
            <label for="nombre" class="form-label">Nombre</label>
            <input type="text" class="form-control" id="nombre" name="nombre" required>
          </div>
          <div class="mb-3">
            <label for="correo" class="form-label">Correo electrónico</label>
            <input type="email" class="form-control" id="correo" name="correo" required>
          </div>
          <div class="mb-3">
            <label for="mensaje" class="form-label">Mensaje</label>
            <textarea class="form-control" id="mensaje" name="mensaje" rows="5" required></textarea>
          </div>
          <div class="text-center">
            <button type="submit" class="btn btn-primary btn-lg">Enviar</button>
          </div>
        </form>
        <!-- Mensaje de confirmación -->
        <div id="formMessage" class="mt-3 text-center"></div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contactForm');
  const formMessage = document.getElementById('formMessage');

  form.addEventListener('submit', async (e) => {
    e.preventDefault(); // evita la redirección

    const data = new FormData(form);
    const response = await fetch(form.action, {
      method: form.method,
      body: data,
      headers: { 'Accept': 'application/json' }
    });

    if (response.ok) {
      formMessage.innerHTML = "<p class='text-success fw-bold'>¡Gracias! Tu mensaje fue enviado correctamente.</p>";
      form.reset(); // limpia los campos
    } else {
      formMessage.innerHTML = "<p class='text-danger fw-bold'>Ocurrió un error. Intenta nuevamente.</p>";
    }
  });
</script>
